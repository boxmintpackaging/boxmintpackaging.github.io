<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --navy:#2C3E5D;--navy-dark:#1E2D45;--mint:#5CD9A6;--mint-dark:#3EC08A;
  --mint-light:#E8F9F1;--cream:#F5F3EE;--cream-dark:#EBE8E0;--gold:#D4AF37;
  --white:#fff;--text:#556B7D;--text-light:#8A9AAD;
  --shadow-sm:0 2px 10px rgba(44,62,93,.08);
  --shadow-md:0 10px 30px rgba(44,62,93,.1);
  --shadow-lg:0 20px 50px rgba(44,62,93,.15)
}
html,body{overflow-x:hidden;max-width:100vw}
body{font-family:'Nunito',sans-serif;color:var(--navy);background:#fff;line-height:1.6}
a{text-decoration:none;color:inherit;cursor:pointer}
ul{list-style:none}
.container{max-width:1250px;margin:0 auto;padding:0 20px;box-sizing:border-box}

.top-bar{background:var(--navy);color:var(--cream);padding:10px 0;font-size:13px;font-weight:600}
.top-bar .container{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px}
.top-bar-info{display:flex;gap:25px;flex-wrap:wrap}
.top-bar-info a,.top-bar-info span{color:var(--cream);display:inline-flex;align-items:center;gap:6px}
.top-bar-info i{color:var(--mint)}
.top-bar-social{display:flex;gap:8px;align-items:center}
.top-bar-social span{font-size:12px;color:var(--text-light)}
.top-bar-social a{width:28px;height:28px;border-radius:50%;border:1px solid rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--cream);transition:.3s}
.top-bar-social a:hover{background:var(--mint);color:var(--navy)}

.header{background:#fff;box-shadow:var(--shadow-sm);position:sticky;top:0;z-index:1000}
.header .container{display:flex;justify-content:space-between;align-items:center;padding:15px 20px}
.logo{display:flex;align-items:center;gap:12px;cursor:pointer}
.logo-icon{width:55px;height:55px;background:#fff;border:2.5px solid var(--navy);border-radius:10px;display:flex;align-items:center;justify-content:center;transition:.4s}
.logo:hover .logo-icon{transform:rotate(360deg);border-color:var(--mint)}
.logo-icon i{color:var(--mint);font-size:26px}
.logo-text{font-size:26px;font-weight:900;color:var(--navy)}
.logo-text span{color:var(--mint)}
.logo-tagline{font-size:10px;color:var(--text);font-weight:700;letter-spacing:2px;text-transform:uppercase}
.nav-links{display:flex;gap:5px;align-items:center;position:relative}
.nav-item{position:relative}
.nav-item>a{padding:10px 14px;color:var(--navy);font-weight:700;font-size:13px;border-radius:6px;transition:.3s;display:inline-flex;align-items:center;gap:5px;white-space:nowrap;cursor:pointer}
.nav-item>a:hover,.nav-item>a.active{color:var(--mint-dark);background:var(--mint-light)}
.nav-item>a i.arrow{font-size:10px;transition:.3s}
.nav-item:hover>a i.arrow{transform:rotate(180deg)}
.dropdown{position:absolute;top:100%;left:0;background:#fff;min-width:250px;padding:15px;border-radius:12px;box-shadow:var(--shadow-lg);opacity:0;visibility:hidden;transform:translateY(10px);transition:.3s;z-index:1000;border:1px solid var(--cream-dark)}
.nav-item:hover .dropdown{opacity:1;visibility:visible;transform:translateY(0)}
.dropdown-item{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;cursor:pointer;background:var(--cream);margin-bottom:5px;transition:.3s;text-decoration:none}
.dropdown-item:hover{background:var(--mint-light);transform:translateX(3px)}
.dropdown-item-icon{width:36px;height:36px;background:#fff;border-radius:8px;display:flex;align-items:center;justify-content:center;color:var(--mint-dark);font-size:16px}
.dropdown-item span{color:var(--navy);font-weight:700;font-size:13px}
.nav-cta{background:linear-gradient(135deg,var(--mint),var(--mint-dark))!important;color:var(--navy)!important;padding:10px 22px!important;border-radius:30px!important;font-weight:800!important;margin-left:8px}
.nav-cta:hover{color:#fff!important;transform:translateY(-2px)}
.hamburger{display:none;font-size:22px;background:var(--mint-light);border:none;color:var(--navy);width:45px;height:45px;border-radius:8px;cursor:pointer}

.page-header{background:linear-gradient(135deg,var(--navy),var(--navy-dark));color:#fff;padding:80px 0;text-align:center}
.page-header h1{font-family:'Playfair Display',serif;font-size:48px;font-weight:900;margin-bottom:15px}
.page-header h1 span{color:var(--mint);font-style:italic}
.page-header p{font-size:17px;color:var(--text-light);max-width:700px;margin:0 auto}
.breadcrumb{display:flex;justify-content:center;gap:10px;margin-top:20px;font-size:14px;color:var(--text-light)}
.breadcrumb a{color:var(--mint);transition:.3s}
.breadcrumb a:hover{color:#fff}

.section{padding:80px 0}
.section-alt{background:var(--cream)}
.section-header{text-align:center;max-width:700px;margin:0 auto 60px}
.section-tag{display:inline-flex;align-items:center;gap:8px;background:var(--mint-light);color:var(--mint-dark);padding:8px 20px;border-radius:25px;font-size:13px;font-weight:800;margin-bottom:18px;text-transform:uppercase;letter-spacing:1px}
.section-header h2{font-family:'Playfair Display',serif;font-size:40px;color:var(--navy);font-weight:900;margin-bottom:15px}
.section-header h2 span{color:var(--mint-dark);font-style:italic}
.section-header p{color:var(--text);font-size:16px}

.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:50px;margin-bottom:60px}
.contact-info-box{background:#fff;padding:40px;border-radius:20px;box-shadow:var(--shadow-md);border:2px solid var(--cream-dark)}
.contact-info-box h3{font-family:'Playfair Display',serif;font-size:28px;color:var(--navy);font-weight:900;margin-bottom:15px}
.contact-info-box h3 span{color:var(--mint-dark);font-style:italic}
.contact-info-box>p{color:var(--text);margin-bottom:30px;line-height:1.7}
.contact-detail{display:flex;align-items:flex-start;gap:15px;padding:15px 0;border-bottom:1px dashed var(--cream-dark)}
.contact-detail:last-child{border:none}
.contact-detail-icon{width:50px;height:50px;min-width:50px;background:var(--mint-light);color:var(--mint-dark);border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:20px}
.contact-detail-text h4{font-size:14px;color:var(--navy);font-weight:800;margin-bottom:5px}
.contact-detail-text p{font-size:13px;color:var(--text);line-height:1.6}
.contact-detail-text a{color:var(--mint-dark);font-weight:700}

.contact-form-box{background:linear-gradient(135deg,var(--navy),var(--navy-dark));padding:40px;border-radius:20px;color:#fff;box-shadow:var(--shadow-lg)}
.contact-form-box h3{font-family:'Playfair Display',serif;font-size:28px;color:#fff;font-weight:900;margin-bottom:10px}
.contact-form-box h3 span{color:var(--mint);font-style:italic}
.contact-form-box>p{color:var(--text-light);margin-bottom:25px;font-size:14px}
.form-group{margin-bottom:18px}
.form-group label{display:block;font-size:12px;font-weight:800;color:var(--mint);margin-bottom:8px;text-transform:uppercase;letter-spacing:1px}
.form-group input,.form-group textarea,.form-group select{width:100%;padding:13px 15px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);border-radius:10px;color:#fff;font-size:13px;font-family:'Nunito',sans-serif;font-weight:600;transition:.3s}
.form-group input:focus,.form-group textarea:focus,.form-group select:focus{outline:none;border-color:var(--mint);background:rgba(255,255,255,0.12)}
.form-group input::placeholder,.form-group textarea::placeholder{color:rgba(255,255,255,0.4)}
.form-group textarea{min-height:100px;resize:vertical}
.form-group select option{background:var(--navy-dark);color:#fff}
.submit-btn{width:100%;padding:16px;background:linear-gradient(135deg,var(--mint),var(--mint-dark));color:var(--navy);border:none;border-radius:12px;font-weight:900;font-size:15px;cursor:pointer;font-family:'Nunito',sans-serif;margin-top:10px;transition:.3s;display:flex;align-items:center;justify-content:center;gap:10px}
.submit-btn:hover{transform:translateY(-3px);color:#fff}

.faq-wrapper{max-width:800px;margin:0 auto}
.faq-item{background:#fff;border:2px solid var(--cream-dark);border-radius:15px;margin-bottom:15px;overflow:hidden;transition:.4s}
.faq-item.active{border-color:var(--mint)}
.faq-question{padding:20px 25px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;font-weight:800;color:var(--navy);font-size:16px;gap:15px}
.faq-question:hover{background:var(--cream)}
.faq-item.active .faq-question{background:var(--mint-light)}
.faq-toggle{width:32px;height:32px;background:var(--mint);color:var(--navy);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;transition:.4s;flex-shrink:0}
.faq-item.active .faq-toggle{transform:rotate(135deg);background:var(--navy);color:var(--mint)}
.faq-answer{max-height:0;overflow:hidden;transition:.4s ease;padding:0 25px}
.faq-item.active .faq-answer{max-height:300px;padding:0 25px 20px}
.faq-answer p{color:var(--text);line-height:1.7;font-size:14px}

.thankyou-popup{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(44,62,93,.85);z-index:99999;display:none;align-items:center;justify-content:center;padding:20px}
.thankyou-popup.show{display:flex}
.thankyou-box{background:#fff;max-width:450px;width:100%;border-radius:20px;padding:40px;text-align:center;box-shadow:var(--shadow-lg)}
.thankyou-icon{width:80px;height:80px;background:linear-gradient(135deg,var(--mint),var(--mint-dark));border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;font-size:40px;color:#fff}
.thankyou-box h2{font-family:'Playfair Display',serif;font-size:30px;color:var(--navy);font-weight:900;margin-bottom:10px}
.thankyou-box p{color:var(--text);margin-bottom:25px;line-height:1.7}
.thankyou-btn{background:linear-gradient(135deg,var(--mint),var(--mint-dark));color:var(--navy);border:none;padding:12px 35px;border-radius:30px;font-weight:900;cursor:pointer;font-family:'Nunito',sans-serif;font-size:14px}

.footer{background:var(--navy);color:var(--text-light);padding:70px 0 30px}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1.2fr;gap:40px;margin-bottom:40px}
.footer-about .footer-logo{display:flex;align-items:center;gap:12px;margin-bottom:20px;cursor:pointer}
.footer-logo-icon{width:50px;height:50px;background:#fff;border-radius:10px;display:flex;align-items:center;justify-content:center}
.footer-logo-icon i{color:var(--mint);font-size:24px}
.footer-logo-text{font-size:24px;font-weight:900;color:#fff}
.footer-logo-text span{color:var(--mint)}
.footer-about p{font-size:14px;line-height:1.8;margin-bottom:20px}
.footer-social{display:flex;gap:10px}
.footer-social a{width:40px;height:40px;background:rgba(255,255,255,.08);border-radius:10px;display:flex;align-items:center;justify-content:center;color:#fff;cursor:pointer;transition:.4s}
.footer-social a:hover{background:var(--mint);color:var(--navy)}
.footer-col h3{color:#fff;font-size:17px;margin-bottom:20px;font-weight:800;position:relative;padding-bottom:12px}
.footer-col h3::after{content:'';position:absolute;bottom:0;left:0;width:35px;height:3px;background:var(--mint);border-radius:2px}
.footer-col ul li{margin-bottom:10px}
.footer-col ul li a{color:var(--text-light);font-size:13px;cursor:pointer;transition:.3s;display:inline-flex;align-items:center;gap:6px}
.footer-col ul li a:hover{color:var(--mint);padding-left:5px}
.footer-contact li{display:flex;align-items:flex-start;gap:12px;margin-bottom:15px;font-size:13px;color:var(--text-light)}
.footer-contact li i{color:var(--mint);margin-top:3px;min-width:15px}
.footer-bottom{text-align:center;padding-top:30px;border-top:1px solid rgba(255,255,255,.08);font-size:13px}
.footer-bottom a{color:var(--mint)}

@media(max-width:1024px){
  .contact-grid{grid-template-columns:1fr;gap:30px}
  .footer-grid{grid-template-columns:1fr 1fr}
  .page-header h1{font-size:36px}
  .section-header h2{font-size:32px}
}
@media(max-width:768px){
  .hamburger{display:flex;align-items:center;justify-content:center}
  .nav-links{display:none;position:absolute;top:100%;left:0;right:0;background:#fff;flex-direction:column;padding:20px;box-shadow:var(--shadow-md);gap:5px}
  .nav-links.open{display:flex}
  .nav-item{width:100%}
  .nav-item>a{width:100%;text-align:left}
  .dropdown{position:static;opacity:1;visibility:visible;transform:none;box-shadow:none;padding:10px;background:var(--cream);margin:5px 0}
  .top-bar .container{justify-content:center}
  .top-bar-social{display:none}
  .footer-grid{grid-template-columns:1fr}
  .page-header{padding:60px 0}
  .page-header h1{font-size:28px}
  .section{padding:50px 0}
  .contact-info-box,.contact-form-box{padding:25px}
  .contact-info-box h3,.contact-form-box h3{font-size:22px}
}
@media(max-width:480px){
  .section-header h2{font-size:24px}
  .page-header h1{font-size:24px}
  .thankyou-box{padding:30px 20px}
}
</style>
</head>
