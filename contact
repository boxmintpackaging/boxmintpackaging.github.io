                </div>
            </div>
        `;
    }
    
    function showWarning(message) {
        const oldWarning = document.getElementById('security-warning');
        if (oldWarning) oldWarning.remove();
        
        const warning = document.createElement('div');
        warning.id = 'security-warning';
        warning.style.cssText = 'position:fixed;top:20px;right:20px;background:linear-gradient(135deg,#ff6b6b,#ee5a6f);color:white;padding:15px 25px;border-radius:10px;box-shadow:0 10px 30px rgba(0,0,0,0.2);font-family:Arial;font-size:14px;z-index:999999;';
        warning.innerHTML = `⚠️ ${message}`;
        document.body.appendChild(warning);
        setTimeout(() => warning.remove(), 3000);
    }
    
    console.clear();
    console.log('%c⛔ STOP!', 'color:red;font-size:60px;font-weight:bold;');
    console.log('%cThis is a protected website!', 'color:red;font-size:20px;font-weight:bold;');
    console.log('%c© BoxMint Packaging - All Rights Reserved', 'color:#667eea;font-size:16px;');
    
})();

